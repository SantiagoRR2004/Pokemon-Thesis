{
  "triggerTaskOnSave.tasks": {
    "Format Code with Black": [
      "*" // <-- Glob pattern to specify which files should trigger the task
      // In this case, all files will trigger the task
    ]
  },
  "python.terminal.activateEnvironment": true,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.formatting.latex": "latexindent",
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk-en",
      "command": "latexmk",
      "args": [
        "--shell-escape",
        "-pdf",
        "-jobname=%DOCFILE%-en",
        "-pdflatex=pdflatex %O \"\\def\\LANG{en}\\input{%S}\"",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ]
    },
    {
      "name": "latexmk-es",
      "command": "latexmk",
      "args": [
        "--shell-escape",
        "-pdf",
        "-jobname=%DOCFILE%-es",
        "-pdflatex=pdflatex %O \"\\def\\LANG{es}\\input{%S}\"",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk (shell escape)",
      "tools": ["latexmk-es", "latexmk-en"]
    }
  ]
}
